generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  displayName  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurants  Restaurant[]
  ratings      Rating[]
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  cuisine   String
  lat       Float?
  lng       Float?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   User     @relation(fields: [createdBy], references: [id])
  ratings   Rating[]
}

model Rating {
  id           String     @id @default(cuid())
  score        Int
  notes        String?
  userId       String
  restaurantId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  tags         Tag[]      @relation("RatingTags")

  @@unique([userId, restaurantId])
}

model Tag {
  id      String   @id @default(cuid())
  name    String   @unique
  ratings Rating[] @relation("RatingTags")
}
