{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "runtime": "vercel-node@latest",
      "includeFiles": "apps/api/src/**/*.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web"
    }
  ]
}
